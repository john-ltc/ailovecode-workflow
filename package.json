{
  "name": "ailovecode-workflow",
  "version": "1.0.0",
  "bin": {
    "ailovecode-workflow": "./bin/ailovecode-workflow.js"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:css": "tailwindcss -i ./src/web/styles.css -o ./dist/web/public/styles.css --minify",
    "build:ts": "tsc",
    "build": "npm run clean && npm run build:css && npm run build:ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "express": "^4.18.3",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
